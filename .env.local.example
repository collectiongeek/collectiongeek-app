# -------------------------------------------------------
# Root .env.local — used by the Convex CLI (npx convex dev),
# the Go backend (auto-loaded by cmd/server), and the
# template-library seed script (npm run seed:templates).
# Copy to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# -------------------------------------------------------

# WorkOS credentials (Staging environment for local dev)
# Set these after running: npx convex dev
WORKOS_CLIENT_ID=client_your_staging_client_id_here
WORKOS_API_KEY=sk_test_your_staging_api_key_here

# Convex admin auth.
# Generate one at: npx convex dashboard → Settings → Deploy keys.
# Use a "Development" key for local dev, "Production" for prod.
# Required by:
#   - the Go backend (talks to Convex internal mutations)
#   - npm run seed:templates (populates the asset-type template library)
# See SETUP.md §9 for the full seeding walkthrough.
CONVEX_DEPLOY_KEY=dev:your_dev_deploy_key_here

# -------------------------------------------------------
# frontend/.env.local — used by Vite dev server
# Copy to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# -------------------------------------------------------

# Go backend (local dev)
VITE_API_BASE_URL=http://localhost:8080

# WorkOS AuthKit — Staging environment client ID
VITE_WORKOS_CLIENT_ID=client_your_staging_client_id_here

# Convex deployment URL — dev project
VITE_CONVEX_URL=https://your-dev-project.convex.cloud

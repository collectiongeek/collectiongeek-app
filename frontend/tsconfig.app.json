{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "es2023",
    "lib": ["ES2023", "DOM"],
    "module": "esnext",
    /* vite/client for import.meta.env etc. "node" is required because the
     * committed Convex generated API (../convex/_generated/api.d.ts) imports
     * the server modules to derive its types, which pulls convex/http.ts — a
     * server file that reads process.env — into this program. Without "node",
     * `process` is undefined there (TS2591). Until the vitest 4 bump a
     * transitive dep happened to leak node's globals here; making it explicit
     * keeps the build deterministic. (Convex is also typechecked on its own
     * via typecheck:convex.) */
    "types": ["vite/client", "node"],
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true,

    /* Path aliases */
    "paths": {
      "@/*": ["./src/*"],
      "@convex-gen/*": ["../convex/_generated/*"],
      "convex": ["./node_modules/convex"],
      "convex/*": ["./node_modules/convex/*"]
    }
  },
  "include": ["src"]
}
